        CAST(NULL AS DOUBLE) AS fgm,
        CAST(NULL AS DOUBLE) AS fta,
        CAST(NULL AS DOUBLE) AS ftm
    LIMIT 0
)
SELECT
    p.player_id,
    p.full_name AS player_name,
    p.position,
    p.team_name,
