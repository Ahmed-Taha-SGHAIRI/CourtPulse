)
SELECT
    s.team_id, s.team_name, s.team_abbreviation,
    s.conference, s.division,
    s.wins, s.losses,
    ROUND(s.wins::FLOAT / NULLIF(s.wins + s.losses, 0), 3) AS win_pct,
    s.conference_rank, s.division_rank,
    s.conference_record, s.home_record, s.road_record,
    ROUND(COALESCE(a.avg_pts_scored,  0), 1) AS avg_pts_scored,
    ROUND(COALESCE(a.avg_pts_allowed, 0), 1) AS avg_pts_allowed,
    ROUND(COALESCE(a.avg_pts_scored, 0) - COALESCE(a.avg_pts_allowed, 0), 1) AS point_diff,
    CASE
        WHEN s.conference_rank <= 6  THEN 'Playoff'
        WHEN s.conference_rank <= 10 THEN 'Play-In'
        ELSE 'Eliminated'
    END AS playoff_status
FROM standings_raw s
LEFT JOIN agg a ON s.team_abbreviation = a.team_abbr
ORDER BY s.conference, s.conference_rank
    );
  
  
