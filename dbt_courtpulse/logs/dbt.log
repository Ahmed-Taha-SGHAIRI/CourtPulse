      WITH games AS (SELECT * FROM "courtpulse"."main"."stg_games"),
standings_raw AS (
    SELECT * FROM read_parquet('/data/parquet/standings/standings_2024.parquet')
),
team_results AS (
    SELECT home_team_name AS team_name, home_team_abbr AS team_abbr,
           SUM(CASE WHEN winner = home_team_name THEN 1 ELSE 0 END) AS home_wins,
           SUM(CASE WHEN winner != home_team_name THEN 1 ELSE 0 END) AS home_losses,
           AVG(home_score) AS avg_pts_scored, AVG(visitor_score) AS avg_pts_allowed
    FROM games GROUP BY 1, 2
    UNION ALL
    SELECT visitor_team_name, visitor_team_abbr,
           0, 0,
           AVG(visitor_score), AVG(home_score)
    FROM games GROUP BY 1, 2
),
agg AS (
    SELECT team_name, team_abbr,
           SUM(home_wins) AS home_wins, SUM(home_losses) AS home_losses,
           AVG(avg_pts_scored) AS avg_pts_scored, AVG(avg_pts_allowed) AS avg_pts_allowed
    FROM team_results GROUP BY 1, 2
)
SELECT
    s.team_id, s.team_name, s.team_abbreviation,
    s.conference, s.division,
    s.wins, s.losses,
    ROUND(s.wins::FLOAT / NULLIF(s.wins + s.losses, 0), 3) AS win_pct,
    s.conference_rank, s.division_rank,
    s.conference_record, s.home_record, s.road_record,
    ROUND(COALESCE(a.avg_pts_scored,  0), 1) AS avg_pts_scored,
    ROUND(COALESCE(a.avg_pts_allowed, 0), 1) AS avg_pts_allowed,
    ROUND(COALESCE(a.avg_pts_scored, 0) - COALESCE(a.avg_pts_allowed, 0), 1) AS point_diff,
    CASE
        WHEN s.conference_rank <= 6  THEN 'Playoff'
        WHEN s.conference_rank <= 10 THEN 'Play-In'
        ELSE 'Eliminated'
    END AS playoff_status
FROM standings_raw s
LEFT JOIN agg a ON s.team_abbreviation = a.team_abbr
ORDER BY s.conference, s.conference_rank
    );
  
  
